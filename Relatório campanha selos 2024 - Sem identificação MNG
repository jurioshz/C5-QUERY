SELECT /*+OPTIMIZER_FEATURES_ENABLE('11.2.0.4')*/
    A.NROEMPRESA                    AS LOJA,
    B.SEQPRODUTO                    AS PLU,
    C.DESCCOMPLETA                  AS ITEM,
    B.VLRITEM                       AS VALOR,
    COUNT(*)                        AS QTD_TRANSACOES
FROM PDV_DOCTO A
INNER JOIN PDV_DOCTOITEM B ON A.SEQDOCTO = B.SEQDOCTO
INNER JOIN MAP_PRODUTO C   ON B.SEQPRODUTO = C.SEQPRODUTO
LEFT JOIN PDV_DESCONTO D   ON A.SEQDOCTO = D.SEQDOCTO
WHERE A.DTAMOVIMENTO BETWEEN DATE '2024-06-25' AND DATE '2024-06-30'
  AND B.SEQPRODUTO IN (260345, 260354, 260346, 260349, 260356, 260358)
  AND D.SEQDOCTO IS NULL
GROUP BY A.NROEMPRESA, B.SEQPRODUTO, C.DESCCOMPLETA, B.VLRITEM
ORDER BY A.NROEMPRESA, B.SEQPRODUTO;


