SELECT
    P.NROEMPRESA,
    PR.DESCCOMPLETA AS PRODUTO,
    P.SEQPRODUTO AS CODINTERNO,
    TO_CHAR(P.DTAINICIO, 'DD/MM/YYYY') AS DATA_INICIO_OFERTA,
    TO_CHAR(P.DTAFIM,    'DD/MM/YYYY') AS DATA_FIM_OFERTA,
    P.PRECOPROMOCAO     AS VALOR_PROMOCAO
FROM consinco.NAGV_BASE_PROMOC_PDV_MN P
INNER JOIN consinco.MAP_PRODUTO PR
        ON PR.SEQPRODUTO = P.SEQPRODUTO
WHERE P.STATUS = 'A'
  AND SYSDATE BETWEEN P.DTAINICIO AND P.DTAFIM
  AND P.NROEMPRESA IN (:frmQVConsultaExecuta.LS1)
ORDER BY
    P.NROEMPRESA,
    PR.DESCCOMPLETA;
